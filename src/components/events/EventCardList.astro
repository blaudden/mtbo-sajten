---
/**
 * Grid of EventCard components. Only accepts fully resolved events.
 */
import type { ScraperEvent } from '~/types/events';
import EventCard from './EventCard.astro';

interface Props {
  /** Pre-resolved events */
  events: ScraperEvent[];
  title?: string;
}

const { events, title } = Astro.props;
---

{
  events.length > 0 && (
    <div class="event-card-list">
      {title && <h2 class="text-2xl md:text-3xl font-bold tracking-tight mb-6 dark:text-white">{title}</h2>}
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {events.map((event) => (
          <EventCard event={event} />
        ))}
      </div>
    </div>
  )
}
