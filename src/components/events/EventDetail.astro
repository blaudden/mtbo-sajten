---
/**
 * Full event detail layout for the event detail page.
 * Orchestrates atomic components: Header, InfoGrid, RaceTable, Documents, Links.
 */
import type { ScraperEvent } from '~/types/events';
import { formatEventDateRange, resolveCountryCode, getOrganiserName, resolveExternalUrl } from '~/utils/events';
import { Icon } from 'astro-icon/components';

import EventHeader from './EventHeader.astro';
import EventInfoGrid from './EventInfoGrid.astro';
import EventRaceTable from './EventRaceTable.astro';
import EventDocuments from './EventDocuments.astro';
import EventLinks from './EventLinks.astro';
import EventDeadlines from './EventDeadlines.astro';
import EventClasses from './EventClasses.astro';
import EventMap from './EventMap.astro';

interface Props {
  event: ScraperEvent;
}

const { event } = Astro.props;
const countryCode = resolveCountryCode(event);
const organiserName = getOrganiserName(event);
const dateRange = formatEventDateRange(event.start_time, event.end_time);
const externalUrl = resolveExternalUrl(event);

// Status badge styling
const statusColors: Record<string, string> = {
  Sanctioned: 'bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-300',
  Planned: 'bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-300',
  Applied: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
  Proposed: 'bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-300',
  Canceled: 'bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-300',
  Rescheduled: 'bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300',
};
const statusColor = statusColors[event.status] || statusColors.Planned;

const statusLabels: Record<string, string> = {
  Sanctioned: 'Godkänd',
  Planned: 'Planerad',
  Applied: 'Ansökt',
  Proposed: 'Föreslagen',
  Canceled: 'Inställd',
  Rescheduled: 'Flyttad',
};
const statusLabel = statusLabels[event.status] || event.status;

// External link logic
const isEventor = externalUrl?.toLowerCase().includes('eventor');
const externalLinkLabel = isEventor
  ? 'Visa på Eventor'
  : externalUrl?.replace(/^https?:\/\/(www\.)?/, '').split('/')[0] || 'Webbplats';
---

<article class="event-detail max-w-4xl mx-auto">
  <EventHeader event={event} countryCode={countryCode} statusLabel={statusLabel} statusColor={statusColor} />

  <div class="mb-6">
    <EventInfoGrid
      dateRange={dateRange}
      organiserName={organiserName}
      region={event.region ?? undefined}
      punchingSystem={event.punching_system ?? undefined}
      discipline={event.races.length === 1 ? event.races[0].discipline : undefined}
    />
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start mt-6">
    {/* Left Column: Information, Classes, Map, Races, Documents, Links */}
    <div class="lg:col-span-8 space-y-8">
      {
        event.information && (
          <div class="p-5 bg-gray-50 dark:bg-slate-800/50 rounded-xl border border-gray-200 dark:border-gray-700 shadow-sm">
            <p class="text-base text-default leading-relaxed whitespace-pre-line">
              {event.information.replace(/\\n/g, '\n')}
            </p>
          </div>
        )
      }

      <EventClasses classes={event.classes} />

      <EventMap event={event} />

      <EventRaceTable event={event} />

      <EventDocuments event={event} />

      <EventLinks event={event} />
    </div>

    {/* Right Column (Sidebar): Sticky CTA & Deadlines */}
    <div class="lg:col-span-4 lg:sticky lg:top-24 space-y-6">
      {
        externalUrl && (
          <div class="p-5 bg-blue-50/50 dark:bg-blue-950/10 border border-blue-100 dark:border-blue-900/30 rounded-2xl space-y-4 shadow-sm">
            <div class="space-y-1">
              <h3 class="font-bold text-base text-default">Sugen på MTBO?</h3>
              <p class="text-sm text-muted">
                Upplev orientering i full fart, anmäl dig till tävlingen på{' '}
                {isEventor ? 'Eventor' : 'tävlingens webbplats'}.
              </p>
            </div>

            <a
              href={externalUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full btn btn-primary py-2.5 px-5 text-sm font-medium inline-flex items-center justify-center gap-2 rounded-xl transition-all shadow-sm shadow-primary/10 hover:shadow-md hover:shadow-primary/20"
            >
              <Icon name="tabler:external-link" class="w-4 h-4" />
              Gå till anmälan
            </a>
          </div>
        )
      }

      <EventDeadlines deadlines={event.entry_deadlines} />
    </div>
  </div>

  {
    externalUrl && (
      <div class="mt-10 pt-6 border-t border-gray-200 dark:border-gray-700">
        <a
          href={externalUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-base font-medium text-primary hover:text-secondary transition-colors group"
        >
          <Icon
            name="tabler:external-link"
            class="w-5 h-5 transition-transform group-hover:-translate-y-0.5 group-hover:translate-x-0.5"
          />
          <span class="truncate max-w-[280px] sm:max-w-none">{externalLinkLabel}</span>
        </a>
      </div>
    )
  }
</article>
