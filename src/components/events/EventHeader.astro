---
/**
 * Header section for EventDetail.
 * Shows country flag, status, and event name.
 */
import type { ScraperEvent } from '~/types/events';
import CountryFlag from './CountryFlag.astro';

interface Props {
  event: ScraperEvent;
  countryCode: string;
  statusLabel: string;
  statusColor: string;
}

const { event, countryCode, statusLabel, statusColor } = Astro.props;
const isCanceled = event.status === 'Canceled';
---

<div class="mb-8">
  <div class="flex items-center gap-3 mb-3">
    <CountryFlag countryCode={countryCode} size="md" />
    <span class={`px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColor}`}>
      {statusLabel}
    </span>
  </div>

  <h1
    class={`text-3xl md:text-4xl font-bold tracking-tight mb-2 ${isCanceled ? 'line-through text-muted' : 'dark:text-white'}`}
  >
    {event.name}
  </h1>
</div>
