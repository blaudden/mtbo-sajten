---
/**
 * Race table for the event detail page.
 */
import type { ScraperEvent } from '~/types/events';
import { formatRaceDate } from '~/utils/events';
import DisciplineBadge from './DisciplineBadge.astro';
import { Icon } from 'astro-icon/components';

interface Props {
  event: ScraperEvent;
}

const { event } = Astro.props;
const raceCount = event.races.length;
const raceTypePlural = 'Deltävlingar';
const raceTypeSingular = 'Deltävling';
const raceHeadingText = raceCount === 1 ? raceTypeSingular : `${raceTypePlural} (${raceCount})`;

const todayStr = new Date().toLocaleDateString('sv-SE', { timeZone: 'Europe/Stockholm' });
---

{
  raceCount >= 1 && (
    <div class="mb-10">
      <h2 class="text-xl font-bold mb-4 flex items-center gap-2 font-heading text-default">
        <Icon name="tabler:flag" class="w-5 h-5 text-primary" />
        {raceHeadingText}
      </h2>

      {/* Desktop table */}
      <div class="hidden md:block overflow-x-auto">
        <table class="w-full text-left">
          <thead>
            <tr class="border-b-2 border-gray-200 dark:border-gray-700">
              <th class="py-3 px-4 text-xs font-bold uppercase tracking-widest text-muted">#</th>
              <th class="py-3 px-4 text-xs font-bold uppercase tracking-widest text-muted">Datum</th>
              <th class="py-3 px-4 text-xs font-bold uppercase tracking-widest text-muted">{raceTypeSingular}</th>
              <th class="py-3 px-4 text-xs font-bold uppercase tracking-widest text-muted text-center">Distans</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
            {event.races.map((race) => {
              const raceParticipants = Object.values(race.start_counts || race.entry_counts || {}).reduce(
                (acc, val) => acc + (val || 0),
                0
              );
              return (
                <tr class="hover:bg-gray-50/50 dark:hover:bg-gray-800/30 transition-colors">
                  <td class="py-3 px-4 text-sm text-muted">{race.race_number}</td>
                  <td class="py-3 px-4 text-sm text-muted whitespace-nowrap">
                    {formatRaceDate(race.datetimez, { includeYear: false })}
                  </td>
                  <td class="py-3 px-4 text-sm text-default font-semibold">
                    <div>{race.name || event.name}</div>
                    {raceParticipants > 0 && (
                      <span class="inline-flex items-center gap-1 mt-0.5 text-xs text-orange-700 dark:text-orange-400 font-medium">
                        <Icon name="tabler:users" class="w-3.5 h-3.5 text-orange-500" />
                        {raceParticipants} {event.start_time >= todayStr ? 'anmälda' : 'startande'}
                      </span>
                    )}
                  </td>
                  <td class="py-3 px-4 text-center">
                    <DisciplineBadge discipline={race.discipline} />
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>

      {/* Mobile race cards */}
      <div class="md:hidden space-y-3">
        {event.races.map((race) => {
          const raceParticipants = Object.values(race.start_counts || race.entry_counts || {}).reduce(
            (acc, val) => acc + (val || 0),
            0
          );
          return (
            <div class="border border-gray-200 dark:border-gray-700 rounded-xl p-4 bg-white dark:bg-slate-900 shadow-sm">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="text-sm font-bold text-default">{race.name || event.name}</p>
                  <p class="text-xs text-muted mt-1 flex flex-wrap items-center gap-1.5">
                    <span>{formatRaceDate(race.datetimez, { includeYear: false })}</span>
                    {raceParticipants > 0 && (
                      <>
                        <span class="text-gray-300 dark:text-gray-600">•</span>
                        <span class="inline-flex items-center gap-1 text-xs text-orange-700 dark:text-orange-400 font-medium">
                          <Icon name="tabler:users" class="w-3.5 h-3.5 text-orange-500" />
                          {raceParticipants} {event.start_time >= todayStr ? 'anmälda' : 'startande'}
                        </span>
                      </>
                    )}
                  </p>
                </div>
                <DisciplineBadge discipline={race.discipline} />
              </div>
            </div>
          );
        })}
      </div>
    </div>
  )
}
