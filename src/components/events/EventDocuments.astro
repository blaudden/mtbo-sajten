---
/**
 * Documents section for event detail page.
 */
import { Icon } from 'astro-icon/components';
import { Image } from 'astro:assets';
import { resolveRelativeUrl, getSmartIconInfo, getRaceTerminology } from '~/utils/events';
import type { ScraperEvent } from '~/types/events';
import liveloxIcon from '~/assets/images/livelox-icon.png';

interface Props {
  event: ScraperEvent;
}

const { event } = Astro.props;

// Aggregate and deduplicate documents from event level and all race levels
const documents: Array<{ title: string; url: string; type: string }> = [];
const seenUrls = new Set<string>();

// Add event-level documents
for (const doc of event.documents || []) {
  if (doc.type === 'EmbargoMap' && !doc.url.startsWith('http')) continue;
  const resolvedUrl = resolveRelativeUrl(doc.url, event);
  if (!seenUrls.has(resolvedUrl)) {
    seenUrls.add(resolvedUrl);
    documents.push({
      title: doc.title,
      url: resolvedUrl,
      type: doc.type,
    });
  }
}

// Add race-level documents
const { singular: term } = getRaceTerminology(event);
const hasMultipleRaces = event.races.length > 1;

for (let i = 0; i < event.races.length; i++) {
  const race = event.races[i];
  const prefix = hasMultipleRaces ? `${term} ${race.race_number || i + 1}: ` : '';
  for (const doc of race.documents || []) {
    if (doc.type === 'EmbargoMap' && !doc.url.startsWith('http')) continue;
    const resolvedUrl = resolveRelativeUrl(doc.url, event);
    if (!seenUrls.has(resolvedUrl)) {
      seenUrls.add(resolvedUrl);
      documents.push({
        title: prefix + doc.title,
        url: resolvedUrl,
        type: doc.type,
      });
    }
  }
}
---

{
  documents.length > 0 && (
    <div class="mb-8">
      <h2 class="text-xl font-semibold mb-4 dark:text-white">Dokument</h2>
      <ul class="space-y-2">
        {documents.map((doc) => {
          const iconInfo = getSmartIconInfo(doc.url, doc.title, doc.type);
          const isLivelox = iconInfo.type === 'image' && iconInfo.source === 'livelox';

          return (
            <li>
              <a
                href={doc.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm text-primary hover:underline"
              >
                {isLivelox ? (
                  <Image src={liveloxIcon} alt="Livelox" class="w-4 h-4 object-contain" />
                ) : (
                  <Icon name={iconInfo.name || 'tabler:file-text'} class="w-4 h-4" />
                )}
                {doc.title}
                {doc.type === 'Bulletin' && <span class="text-xs text-muted dark:text-slate-500">({doc.type})</span>}
              </a>
            </li>
          );
        })}
      </ul>
    </div>
  )
}
